# SnappyFresh Environment Configuration

# Server & API
NEXT_PUBLIC_API_URL=https://yomilk.erpona.com:8092
NEXT_PUBLIC_IMAGE_CDN=https://yomilk.erpona.com:3330

# Authentication
IRON_SESSION_PASSWORD=your-secret-password-min-32-chars

# Email (if needed for contact forms)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# Analytics & Monitoring
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Node Environment
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# Feature Flags (optional)
NEXT_PUBLIC_ENABLE_DEBUG=false
NEXT_PUBLIC_ENABLE_ANALYTICS=true
